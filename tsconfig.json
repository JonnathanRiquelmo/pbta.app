{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@auth/*": ["src/auth/*"],
      "@shared/*": ["src/shared/*"],
      "@routes/*": ["src/routes/*"],
      "@campaigns/*": ["src/campaigns/*"],
      "@characters/*": ["src/characters/*"],
      "@moves/*": ["src/moves/*"],
      "@sessions/*": ["src/sessions/*"],
      "@rolls/*": ["src/rolls/*"]
    }
  },
  "include": ["src"]
}