rules_version = '2';
service cloud.firestore {
  match /databases/{db}/documents {
    function isAuthed() {
      return request.auth != null;
    }
    function campaignDoc(campaignId) {
      return get(/databases/$(db)/documents/campaigns/$(campaignId));
    }
    function isOwner(campaignId) {
      return isAuthed() && campaignDoc(campaignId).data.ownerId == request.auth.uid;
    }
    function isSessionOwner(sessionId) {
      return isAuthed() && get(/databases/$(db)/documents/sessions/$(sessionId)).data.campaignId != null
        && get(/databases/$(db)/documents/campaigns/$(get(/databases/$(db)/documents/sessions/$(sessionId)).data.campaignId)).data.ownerId == request.auth.uid;
    }
    function isPlayer(campaignId) {
      return isAuthed()
        && (campaignDoc(campaignId).data.playersUids is list)
        && (request.auth.uid in campaignDoc(campaignId).data.playersUids);
    }
    function intInRange(v, min, max) {
      return v is int && v >= min && v <= max;
    }
    function validAttrs(attrs) {
      return intInRange(attrs.forca, -1, 3)
        && intInRange(attrs.agilidade, -1, 3)
        && intInRange(attrs.sabedoria, -1, 3)
        && intInRange(attrs.carisma, -1, 3)
        && intInRange(attrs.intuicao, -1, 3)
        && (attrs.forca + attrs.agilidade + attrs.sabedoria + attrs.carisma + attrs.intuicao == 3);
    }
    function validMoveModifier(m) {
      return intInRange(m, -1, 3);
    }
    function belongsToUser(sheetId) {
      return get(/databases/$(db)/documents/characters/$(sheetId)).data.userId == request.auth.uid;
    }

    match /campaigns/{campaignId} {
      allow read: if isAuthed();
      allow create: if isAuthed() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isOwner(campaignId)
        || (
          isAuthed()
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['playersUids'])
          && (request.resource.data.playersUids is list)
          && (request.auth.uid in request.resource.data.playersUids)
          && (
            (('playersUids' in resource.data) && !(request.auth.uid in resource.data.playersUids) && request.resource.data.playersUids.size() == resource.data.playersUids.size() + 1)
            || (!('playersUids' in resource.data) && request.resource.data.playersUids.size() == 1)
          )
        );
      allow delete: if isOwner(campaignId);
    }

    match /characters/{characterId} {
      allow read: if isAuthed() && (isOwner(resource.data.campaignId) || isPlayer(resource.data.campaignId));
      allow create: if isAuthed()
        && validAttrs(request.resource.data.attributes)
        && (
          (request.resource.data.type == 'player'
            && isPlayer(request.resource.data.campaignId)
            && request.auth.uid == request.resource.data.userId
            && characterId == request.resource.data.campaignId + '_' + request.auth.uid)
          ||
          (request.resource.data.type == 'npc'
            && isOwner(request.resource.data.campaignId))
        );
      allow update: if isAuthed()
        && validAttrs(request.resource.data.attributes)
        && (
          (request.resource.data.type == 'player'
            && isPlayer(request.resource.data.campaignId)
            && request.auth.uid == request.resource.data.userId)
          ||
          (request.resource.data.type == 'npc'
            && isOwner(request.resource.data.campaignId))
        );
      allow delete: if isOwner(resource.data.campaignId);
    }

    match /npcs/{npcId} {
      allow read: if isAuthed() && (isOwner(resource.data.campaignId) || isPlayer(resource.data.campaignId));
      allow create, update, delete: if isAuthed()
        && isOwner(request.resource.data.campaignId)
        && validAttrs(request.resource.data.attributes);
    }

    match /moves/{moveId} {
      allow read: if isAuthed() && (isOwner(resource.data.campaignId) || isPlayer(resource.data.campaignId));
      allow create, update, delete: if isAuthed()
        && isOwner(request.resource.data.campaignId)
        && validMoveModifier(request.resource.data.modifier)
        && request.resource.data.name is string && request.resource.data.name.size() > 0;
    }

    match /sessions/{sessionId} {
      allow read: if isAuthed() && (isOwner(resource.data.campaignId) || isPlayer(resource.data.campaignId));
      allow create, update: if isAuthed()
        && isOwner(request.resource.data.campaignId)
        && request.resource.data.name is string && request.resource.data.name.size() > 0
        && request.resource.data.date is int && request.resource.data.date > 0;
      allow delete: if isSessionOwner(sessionId);
    }

    match /rolls/{rollId} {
      allow read: if isAuthed() && (isOwner(resource.data.campaignId) || isPlayer(resource.data.campaignId));
      allow create: if isAuthed()
        && (
          (request.resource.data.isPDM == true && isOwner(request.resource.data.campaignId))
          ||
          (
            (request.resource.data.isPDM == false || !("isPDM" in request.resource.data))
            && isPlayer(request.resource.data.campaignId)
          )
        );
      allow delete: if isOwner(resource.data.campaignId);
    }

    match /invites/{inviteId} {
      allow read: if isAuthed();
      allow create: if isAuthed() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuthed()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['usesCount'])
        && request.resource.data.usesCount is int
        && resource.data.usesCount is int
        && request.resource.data.usesCount >= resource.data.usesCount;
      allow delete: if isAuthed() && resource.data.createdBy == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isAuthed();
      allow create: if isAuthed() && request.auth.uid == userId;
      allow update: if isAuthed() && request.auth.uid == userId;
      allow delete: if false; // Não permite deletar usuários
    }
  }
}
